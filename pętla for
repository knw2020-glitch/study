# zadanie 3
# prosta gra w odliczanie    

print("Start za...")

for i in range(5, 0, -1):
    print(i)
    
print("GO!")

# jeśli chciałbyś, zeby liczby pojawiały się powoli to trzeba użyć funkcji tiem.sleep() -> w nawiasie wpisujesz sekundy ile ma spać
# aby funkcja sleep działała, trzeba wczytać moduł time.
# moduły wczytujmey -> import time -> wszystkie potrzebne moduły wczytujemy na początku pliku

import time

for i in range(5, 0, -1):
    print(i)
    time.sleep(2)   #usypia na 2 sekundy
print("GO!")


