# LISTA
# Lista jest po to, żeby trzymać wiele rzeczy naraz. 
# zliczanie elementów z listy
# np lista kolory:  kolory = ["czerwony", "zielony", "niebieski"]
# każdy element w liście ma swój numer liczony od 0   (czyli u nas 0,1,2)
# np. print(kolory[1])   wyświetli kolor "zielony"
# np. print(kolory[0])   wyświetli kolor "czerwony"

kolory = ["czerwony", "zielony", "niebieski"]
print(kolory[1])

# wszystkie kolory z listy wypisze:

kolory = ["czerwony", "zielony", "niebieski"]

for kolor in kolory:
    print(kolor)
    
# ZADANIE
# Suma punktów z listy
# wskazówka, na poczatku zerujemy zmienną w której przechowyjemy punkty, zeby przy kolejnym uruchomieniu była pusta.

punkty = [5, 8, 10, 7, 9]

suma = 0
for p in punkty:
    suma += p       #  ->  w skrócie jest to zapis który oznacza       suma = suma + p
print("Suma:", suma)



